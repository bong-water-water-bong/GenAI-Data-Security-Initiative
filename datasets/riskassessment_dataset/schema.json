{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://owasp.org/dsgai/datasets/riskassessment_dataset/schema.json",
  "title": "DSGAI Deployment Risk Assessment Entry",
  "description": "Schema for a single deployment risk assessment in the OWASP DSGAI riskassessment_dataset. Each entry models a GenAI deployment archetype and walks DSGAI risks, controls, control gaps, and framework alignments. Entries MUST be anonymized or synthetic.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assessment_id",
    "scenario_name",
    "entry_type",
    "industry_sector",
    "deployment_pattern",
    "description",
    "components",
    "risks_identified",
    "framework_alignments",
    "date_added"
  ],
  "properties": {
    "$schema": {
      "description": "Optional pointer to the schema file for editor tooling. Ignored by validators.",
      "type": "string"
    },
    "assessment_id": {
      "description": "Internal identifier, e.g. DSGAI-RA-customer-rag-banking.",
      "type": "string",
      "pattern": "^DSGAI-RA-[a-z0-9-]+$"
    },
    "scenario_name": {
      "description": "Short human-readable name for the deployment archetype.",
      "type": "string",
      "minLength": 8,
      "maxLength": 200
    },
    "entry_type": {
      "description": "How the assessment was sourced.",
      "type": "string",
      "enum": ["synthetic_template", "anonymized_real", "public_reference_architecture"]
    },
    "industry_sector": {
      "description": "Primary sector context for the assessment.",
      "type": "string",
      "enum": [
        "financial_services",
        "healthcare",
        "public_sector",
        "education",
        "retail_ecommerce",
        "manufacturing",
        "technology_saas",
        "energy_utilities",
        "legal_professional_services",
        "hospitality_travel",
        "media_marketing",
        "automotive",
        "telecom",
        "cybersecurity",
        "hr_staffing",
        "cross_sector",
        "other"
      ]
    },
    "deployment_pattern": {
      "description": "Architectural pattern of the deployment.",
      "type": "string",
      "enum": [
        "customer_facing_chatbot",
        "internal_knowledge_assistant",
        "code_assistant",
        "multi_agent_workflow",
        "content_generation",
        "browser_endpoint_assistant",
        "email_triage",
        "search_aggregator",
        "training_or_data_pipeline",
        "mlops_platform",
        "voice_assistant",
        "decision_support",
        "soc_analyst_copilot",
        "self_hosted_inference",
        "embedded_saas_feature",
        "other"
      ]
    },
    "description": {
      "description": "Plain-text description of the deployment scenario, including the data the system handles and who interacts with it. 3-8 sentences.",
      "type": "string",
      "minLength": 80
    },
    "assumptions": {
      "description": "Stated assumptions about the deployment that scope the assessment.",
      "type": "array",
      "items": { "type": "string", "minLength": 8 }
    },
    "components": {
      "description": "Architectural components in scope. List the major moving parts of the deployment.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "description"],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "llm_provider",
              "fine_tuned_adapter",
              "embedding_model",
              "vector_store",
              "rag_pipeline",
              "agent_framework",
              "tool_or_plugin",
              "inference_server",
              "training_pipeline",
              "data_source",
              "identity_provider",
              "guardrail_or_filter",
              "observability_stack",
              "browser_extension_or_endpoint",
              "client_application",
              "mcp_server",
              "other"
            ]
          },
          "description": { "type": "string", "minLength": 4 },
          "sensitivity_tier": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        }
      },
      "minItems": 3
    },
    "risks_identified": {
      "description": "DSGAI risks that apply, each with inherent (before controls) and residual (after controls) severity ratings.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dsgai_id", "inherent_rating", "rationale"],
        "properties": {
          "dsgai_id": {
            "type": "string",
            "enum": [
              "DSGAI01", "DSGAI02", "DSGAI03", "DSGAI04", "DSGAI05",
              "DSGAI06", "DSGAI07", "DSGAI08", "DSGAI09", "DSGAI10",
              "DSGAI11", "DSGAI12", "DSGAI13", "DSGAI14", "DSGAI15",
              "DSGAI16", "DSGAI17", "DSGAI18", "DSGAI19", "DSGAI20", "DSGAI21"
            ]
          },
          "inherent_rating": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low", "Informational"]
          },
          "rationale": { "type": "string", "minLength": 20 },
          "residual_rating": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low", "Informational"]
          },
          "residual_rationale": { "type": "string" }
        }
      },
      "minItems": 5
    },
    "existing_controls": {
      "description": "Mitigations assumed already in place in this archetype.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description": { "type": "string", "minLength": 8 },
          "tier": {
            "type": "string",
            "enum": ["Tier 1", "Tier 2", "Tier 3"]
          },
          "addresses_dsgai": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^DSGAI\\d{2}$"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "control_gaps": {
      "description": "Mitigations that are missing or weak in this archetype.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "urgency"],
        "properties": {
          "description": { "type": "string", "minLength": 8 },
          "addresses_dsgai": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^DSGAI\\d{2}$"
            },
            "uniqueItems": true
          },
          "suggested_remediation": { "type": "string", "minLength": 8 },
          "urgency": {
            "type": "string",
            "enum": ["Immediate", "Near-term", "Strategic"]
          }
        }
      }
    },
    "framework_alignments": {
      "description": "Mappings of this deployment's posture to recognized framework controls.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["framework", "control_id", "alignment_status"],
        "properties": {
          "framework": {
            "type": "string",
            "enum": [
              "NIST CSF 2.0",
              "NIST AI RMF 1.0",
              "ISO/IEC 42001",
              "ISO/IEC 27001",
              "CIS Controls v8",
              "OWASP LLM Top 10 2025",
              "OWASP Agentic Top 10 2026",
              "MITRE ATLAS",
              "MITRE ATT&CK",
              "EU AI Act",
              "GDPR",
              "HIPAA",
              "FERPA",
              "PCI DSS 4.0",
              "SOC 2",
              "FedRAMP",
              "Other"
            ]
          },
          "control_id": { "type": "string", "minLength": 1 },
          "control_name": { "type": "string" },
          "alignment_status": {
            "type": "string",
            "enum": ["satisfied", "partial", "missing", "not_applicable"]
          },
          "notes": { "type": "string" }
        }
      },
      "minItems": 4
    },
    "compliance_obligations": {
      "description": "Statutory or contractual regimes the deployment likely operates under.",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "GDPR",
          "CCPA",
          "HIPAA",
          "FERPA",
          "GLBA",
          "PCI DSS",
          "EU AI Act",
          "SOC 2",
          "FedRAMP",
          "ISO 27001 certification",
          "ISO 42001 certification",
          "NYDFS Part 500",
          "DORA",
          "UK Data Protection Act 2018",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "maturity_overall": {
      "description": "Overall data-security maturity for this archetype on a CMMI-like scale.",
      "type": "string",
      "enum": ["Initial", "Developing", "Defined", "Managed", "Optimizing"]
    },
    "source_urls": {
      "description": "Any inspirational references (vendor reference architectures, published case studies). Not required for synthetic templates.",
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "uniqueItems": true
    },
    "date_added": {
      "description": "Date the entry was added to the dataset (ISO 8601 date).",
      "type": "string",
      "format": "date"
    },
    "tags": {
      "description": "Free-form classification tags.",
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "notes": {
      "description": "Author notes, scope caveats, what this archetype deliberately abstracts away.",
      "type": "string"
    }
  }
}
